{
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:next\" \"pnpm db:studio\"",
    "dev:next": "npx tsx scripts/dev-next.ts",
    "build": "next build",
    "start": "next start",
    "db:setup": "npx tsx lib/data/db/setup.ts",
    "db:seed": "npx tsx lib/data/db/seed.ts",
    "db:reset": "npx tsx lib/data/db/reset.ts",
    "db:seed:permissions": "npx tsx lib/data/db/seed-permissions.ts",
    "db:assign-role": "npx tsx lib/data/db/assign-role.ts",
    "db:reset-password": "npx tsx lib/data/db/reset-password.ts",
    "generate:embeddings": "npx tsx scripts/generate-embeddings.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.mts",
    "db:migrate": "npx tsx scripts/migrate.ts",
    "release": "npx tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.mts",
    "lint": "npx eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "test:integration": "node scripts/run-integration-tests.mjs",
    "test:integration:force": "vitest run --config vitest.integration.config.ts",
    "db:sync": "npx tsx scripts/db-sync.ts",
    "db:migrate:prod": "npx tsx scripts/migrate.ts",
    "codemod:buttons": "npx tsx scripts/migrate-buttons.ts --write",
    "codemod:buttons:report": "npx tsx scripts/migrate-buttons.ts --report",
    "codemod:inputs": "npx tsx scripts/migrate-inputs.ts --write",
    "codemod:inputs:report": "npx tsx scripts/migrate-inputs.ts --report"
  },
